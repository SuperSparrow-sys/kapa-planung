# Kapa-Planung -- Umgebungsvariablen
# Kopiere diese Datei nach .env und passe sie an

# Datenbank-Pfad (Standard: ./kapa.db)
KAPA_DB_PATH=./kapa.db

# Server
KAPA_HOST=0.0.0.0
KAPA_PORT=5050

# Debug-Modus (true/false) -- NIEMALS in Produktion auf true setzen
KAPA_DEBUG=false

# Secret Key fuer Flask-Sessions (beliebig aendern)
KAPA_SECRET_KEY=kapa-dev-key-change-in-production

# Logging
KAPA_LOG_FILE=./kapa.log
KAPA_LOG_LEVEL=INFO

# Backup (lokal)
KAPA_BACKUP_DIR=./backups
KAPA_BACKUP_MAX=10

# Backup (NAS via SCP) -- Konfiguration in backup.env (Laufzeit-Datei)
# Siehe backup.py / Einstellungen-Modal. Bei Erststart wird backup.env
# automatisch angelegt. Enthält BACKUP_1_HOST, _USER, _BASE, _SSH_KEY,
# BACKUP_2_* sowie BACKUP_UNLOCK_PASSWORD und Laufzeit-Statistiken.

# Rate Limiting (Anfragen pro IP pro Fenster)
KAPA_RATE_LIMIT=60
KAPA_RATE_WINDOW=60

# SQLite Retry bei Lock (max. Versuche, Backoff-Sekunden)
KAPA_SQLITE_RETRY=5
KAPA_SQLITE_BACKOFF=0.1

# Standard-Teammitglieder (kommagetrennt)
KAPA_TEAM_SEED=Dominic Meier,Tony Freudenthal
