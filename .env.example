# Kapa-Planung -- Umgebungsvariablen
# Kopiere diese Datei nach .env und passe sie an

# Datenbank-Pfad (Standard: ./kapa.db)
KAPA_DB_PATH=./kapa.db

# Server
KAPA_HOST=0.0.0.0
KAPA_PORT=5050

# Debug-Modus (true/false) -- NIEMALS in Produktion auf true setzen
KAPA_DEBUG=false

# Secret Key fuer Flask-Sessions (beliebig aendern)
KAPA_SECRET_KEY=kapa-dev-key-change-in-production

# Logging
KAPA_LOG_FILE=./kapa.log
KAPA_LOG_LEVEL=INFO

# Backup (lokal)
KAPA_BACKUP_DIR=./backups
KAPA_BACKUP_MAX=10

# Backup (NAS via SCP) -- Werte optional via backup.env setzbar
# KAPA_BACKUP_NAS_HOST=100.107.210.109
# KAPA_BACKUP_NAS_USER=FrankWeiskopf
# KAPA_BACKUP_NAS_BASE=/volume1/homes/FrankWeiskopf/kapa_backup
# KAPA_BACKUP_NAS_KEY=          # leer = ~/.ssh/id_ed25519 oder id_rsa
# KAPA_NAS_DAILY_KEEP=7         # Anzahl taeglicher Backups auf der NAS
# KAPA_NAS_AUTO=false           # Automatisch um 02:00 + 22:00 auf NAS sichern
# KAPA_BACKUP_ENV=./backup.env  # Runtime-Datei fuer NAS-Konfig + Stats

# Rate Limiting (Anfragen pro IP pro Fenster)
KAPA_RATE_LIMIT=60
KAPA_RATE_WINDOW=60

# SQLite Retry bei Lock (max. Versuche, Backoff-Sekunden)
KAPA_SQLITE_RETRY=5
KAPA_SQLITE_BACKOFF=0.1

# Standard-Teammitglieder (kommagetrennt)
KAPA_TEAM_SEED=Dominic Meier,Tony Freudenthal
